{
  "name": "step-sequencer",
  "version": "1.0.0",
  "description": "Interactive 4x4 Step Sequencer with MIDI Output",
  "main": "build-scripts/electron-setup.js",
  "scripts": {
    "electron": "electron .",
    "electron-dev": "NODE_ENV=development electron .",
    "build": "npm run build-react && npm run build-electron",
    "build-react": "npm run build",
    "build-electron": "electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "dist-portable": "npm run build && electron-builder --portable --publish=never"
  },
  "build": {
    "appId": "com.stepsequencer.app",
    "productName": "Interactive Step Sequencer",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "build-scripts/electron-setup.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-reload": "^2.0.0-alpha.1"
  }
}